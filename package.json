{
  "name": "synapse-mcp",
  "version": "1.0.0",
  "description": "Synapse MCP — Code Intelligence Server",
  "type": "module",
  "scripts": {
    "dev": "concurrently --names \"API,UI\" --prefix-colors \"cyan,magenta\" \"node --experimental-sqlite --import tsx/esm src/server.ts\" \"cd web_ui/frontend && npm run dev\"",
    "dev:api": "node --experimental-sqlite --import tsx/esm src/server.ts",
    "dev:ui": "cd web_ui/frontend && npm run dev",
    "start": "node --experimental-sqlite --import tsx/esm src/server.ts",
    "mcp": "node --experimental-sqlite --import tsx/esm src/mcp.ts",
    "build": "tsc",
    "build:frontend": "cd web_ui/frontend && npm install && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "glob": "^10.4.1",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5"
  }
}
